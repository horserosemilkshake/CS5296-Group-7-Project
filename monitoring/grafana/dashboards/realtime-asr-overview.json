{
  "id": null,
  "uid": "realtime-asr-overview",
  "title": "Realtime ASR Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["realtime-asr", "health"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gateway Requests/s",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"gateway\"}[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "NLP Requests/s",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"nlp\"}[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Gateway 5xx",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"gateway\",status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "NLP 5xx",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"nlp\",status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "values": false},
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Gateway P95 Latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"gateway\"}[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "NLP P95 Latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"nlp\"}[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Total Pod CPU Usage (cores)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*kubepods.*\"}[1m]))",
          "refId": "A",
          "legendFormat": "pods"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Total Pod Memory Usage (MiB)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{id=~\".*kubepods.*\"}) / 1024 / 1024",
          "refId": "A",
          "legendFormat": "pods"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GPU Utilization (%)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 21},
      "targets": [
        {
          "expr": "sum(DCGM_FI_DEV_GPU_UTIL) or sum(container_accelerator_duty_cycle{namespace=\"realtime-asr\",container!=\"\"}) or vector(0)",
          "refId": "A",
          "legendFormat": "gpu"
        }
      ]
    }
  ]
}
